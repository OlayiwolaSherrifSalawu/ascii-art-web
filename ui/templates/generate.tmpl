{{define "generate-base"}}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Generator — TypAscii</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cabinet+Grotesk:wght@300;400;500;700;800&family=Fragment+Mono:ital@0;1&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/static/css/style.css"/>
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" defer></script>
  <script>(function(){ var t=localStorage.getItem('theme')||'dark'; document.documentElement.setAttribute('data-theme',t); })();</script>
</head>
<body>

<!-- TOPBAR -->
<header class="topbar">
  <a href="/" class="topbar__logo">TYP<b>ASCII</b></a>
  <nav>
    <ul class="topbar__nav">
      <li><a href="#">Fonts</a></li>
      <li><a href="#">Gallery</a></li>
      <li><a href="#">Docs</a></li>
      <li><a href="#">Login</a></li>
    </ul>
  </nav>
  <div class="topbar__right">
    <button class="theme-btn" id="themeBtn" aria-label="Toggle theme">
      <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <a href="/" class="btn btn-ghost btn-sm">← Home</a>
  </div>
</header>

<!-- APP SHELL -->
<div class="app">

  <!-- ═══ SIDEBAR ═══ -->
  <aside class="sidebar">
    <div class="sidebar__head">
      <div class="sidebar__title">GENERATOR</div>
      <div class="sidebar__sub">Type · Choose · Export</div>
    </div>

    <div class="sidebar__body">

      <!-- TEXT INPUT — the primary HTMX form -->
      <form
        id="ascii-form"
        method="POST"
        action="/ascii-art"
        hx-post="/ascii-art"
        hx-target="#result"
        hx-swap="innerHTML"
        hx-trigger="input changed delay:.120ms from:#txt, change from:input[name=banner]"
        hx-indicator="#spinner"
      >
        <div style="margin-bottom:18px;">
          <label class="lbl" for="txt">Your text</label>
          <textarea
            class="textarea"
            id="txt"
            name="text"
            placeholder="Type anything..."
            rows="5"
            autocomplete="off"
            spellcheck="false"
            maxlength="200"
            oninput="document.getElementById('cc').textContent=this.value.length+'/200'"
          ></textarea>
          <div class="char-count"><span id="cc">0/200</span></div>
        </div>

        <!-- FONT GRID — 2-col tiles, scales to any number of fonts -->
        <div>
          <label class="lbl">Font style</label>
          <div class="font-grid" id="font-grid">

            <label class="ftile on" id="tile-standard">
              <input type="radio" name="banner" value="standard" checked/>
              <span class="ftile__dot"><svg viewBox="0 0 10 10"><polyline points="2,5 4.5,7.5 8,2.5"/></svg></span>
              <span class="ftile__name">Standard</span>
<pre class="ftile__pre"> _   _
| | | |
| |_| |
|  _  |
|_| |_|</pre>
            </label>

            <label class="ftile" id="tile-shadow">
              <input type="radio" name="banner" value="shadow"/>
              <span class="ftile__dot"><svg viewBox="0 0 10 10"><polyline points="2,5 4.5,7.5 8,2.5"/></svg></span>
              <span class="ftile__name">Shadow</span>
<pre class="ftile__pre">  ___|
\___ \
      |
 ___/ /
|____/</pre>
            </label>

            <label class="ftile" id="tile-thinkertoy">
              <input type="radio" name="banner" value="thinkertoy"/>
              <span class="ftile__dot"><svg viewBox="0 0 10 10"><polyline points="2,5 4.5,7.5 8,2.5"/></svg></span>
              <span class="ftile__name">Thinker-Toy</span>
<pre class="ftile__pre">o-O-o
  |
  |
  |
o-o-o</pre>
            </label>

            <!--
              ADD MORE FONTS HERE — just copy a label.ftile block:

            <label class="ftile" id="tile-yourfont">
              <input type="radio" name="banner" value="yourfont"/>
              <span class="ftile__dot"><svg viewBox="0 0 10 10"><polyline points="2,5 4.5,7.5 8,2.5"/></svg></span>
              <span class="ftile__name">Your Font</span>
              <pre class="ftile__pre">preview\nchars\nhere</pre>
            </label>

              The 2-col grid automatically wraps. No CSS changes needed.
            -->

          </div>
        </div>

      </form>
    </div><!-- /sidebar__body -->

    <!-- ACTION BUTTONS -->
    <div class="sidebar__foot">

      <!-- Copy: re-submits form, then reads the rendered <pre> -->
      <button
        type="button"
        class="btn btn-ghost btn-full"
        hx-post="/ascii-art"
        hx-include="#ascii-form"
        hx-target="#result"
        hx-swap="innerHTML"
        hx-on::after-request="
          var p = document.querySelector('#result pre');
          if(p) navigator.clipboard.writeText(p.innerText).catch(function(){});
          var b = document.getElementById('copy-btn');
          b.textContent='Copied!';
          setTimeout(function(){ b.textContent='Copy to clipboard'; }, 1800);
        "
        id="copy-btn"
      >Copy to clipboard</button>

      <!-- Download .txt — native POST, Content-Disposition triggers browser save dialog -->
      <form id="dl-form" method="POST" action="/ascii-art/download">
        <input type="hidden" name="text"   id="dl-text"/>
        <input type="hidden" name="banner" id="dl-banner" value="standard"/>
        <button
          type="submit"
          class="btn btn-ring btn-full"
          hx-on:click="
            document.getElementById('dl-text').value = document.getElementById('txt').value;
            var checked = document.querySelector('#ascii-form input[name=banner]:checked');
            document.getElementById('dl-banner').value = checked ? checked.value : 'standard';
          "
        >Download .txt</button>
      </form>

    </div>
  </aside>

  <!-- ═══ OUTPUT PANEL ═══ -->
  <section class="output">

    <div class="output__bar">
      <span class="output__status">
        <span class="sdot live"></span>
        Live output
      </span>
      <div class="output__tools">
        <span class="htmx-indicator" id="spinner">
          <span class="spin"></span>
        </span>
        <span
          style="font-family:var(--f-mono);font-size:0.6875rem;color:var(--text-faint);padding:0 8px;align-self:center;"
          id="font-badge"
        >standard</span>
      </div>
    </div>

    <div class="output__canvas">
      <div id="result">
        <div class="empty">
<pre class="empty__ascii"> _____ _   _  ____  _     ____  ____  ____  _____
|_   _| | | ||  _ \| |   |  _ \|  _ \/ ___||_   _|
  | | | |_| || |_) | |   | |_) | |_) \___ \  | |
  | | |  _  ||  __/| |___|  _ &lt;|  __/ ___) | | |
  |_| |_| |_||_|   |_____|_| \_\_|   |____/  |_|</pre>
          <span class="empty__hint">Start typing to generate</span>
        </div>
      </div>
    </div>

  </section>

</div><!-- /app -->

<script>
  /* theme toggle */
  document.getElementById('themeBtn').addEventListener('click', function(){
    var h = document.documentElement;
    var n = h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    h.setAttribute('data-theme', n);
    localStorage.setItem('theme', n);
  });

  /* font tile active state + badge update */
  document.getElementById('font-grid').addEventListener('change', function(e){
    if(e.target.type !== 'radio') return;
    document.querySelectorAll('.ftile').forEach(function(t){ t.classList.remove('on'); });
    e.target.closest('.ftile').classList.add('on');
    document.getElementById('font-badge').textContent = e.target.value;
  });
</script>
</body>
</html>
{{end}}
